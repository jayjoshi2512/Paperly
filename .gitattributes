# Normalize all text files to LF on commit, convert to CRLF on Windows checkout
* text=auto eol=lf

# Force LF for Python files
*.py text eol=lf

# Force LF for JS/TS/JSX/TSX files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# Force LF for config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.env text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary files - no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
